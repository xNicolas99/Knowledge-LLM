# --- External LLM (OpenAI-compatible) ---
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=dummy
LLM_MODEL=your-chat-model

# --- External Embedding (OpenAI-compatible) ---
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=dummy
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_DIM=768

# --- Knowledge Base ---
KNOWLEDGE_CATEGORIES=it,science,biology,business,general
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
CONFLICT_THRESHOLD=0.75
CONFLICT_CHECK_ALL_CATEGORIES=false
CLEAN_TEXT=true
CLEAN_MIN_RATIO=0.5
CLEAN_MAX_RATIO=1.15
CLEAN_BLOCK_CHARS=6000

# --- Web Search ---
WEBSEARCH_TOP_K=5
WEBSEARCH_EVALUATE=true
WEBSEARCH_MAX_CHARS=4000
WEBSEARCH_EVAL_CHARS=6000
CRAWL4AI_TOKEN=
CRAWL_CONCURRENCY=3

# --- SearXNG ---
SEARXNG_SECRET=change-me-generate-random
SEARXNG_BASE_URL=http://localhost:8080/

# --- Security / Domain ---
API_KEY=change-me
REQUIRE_AUTH_FOR_READ=true
PUBLIC_HOSTNAME=research.example.com
